#include <iostream>
#include <string>
using namespace std;
int main() {
    string nama;
    int umur;

    // Input nama
    cout << "Nama : ";
    getline(cin, nama);

    // Input umur
    cout << "Umur : ";
    cin >> umur;

    // Output
    cout << endl;
    cout << "Nama Anda : " << nama << endl;
    cout << "Umur Anda : " << umur << endl;

    return 0;
}
